API_HOST=0.0.0.0
API_PORT=8000

# Anomaly detection threshold (0.0 – 1.0).
# Events with an anomaly_score above this value are flagged.
ANOMALY_THRESHOLD=0.5

# SQLite database file path (relative to apps/api/)
DATABASE_URL=sqlite:///./dtx_ai.db

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Set to "true" to enable verbose AI pipeline logging
AI_DEBUG=false
